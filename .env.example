# 複製此檔案為 .env，填入真實數值，.env 不可 commit 到 git
# cp .env.example .env

# ── Gemini / LiteLLM ──────────────────
GEMINI_API_KEY=

# ── LINE Bot ──────────────────────────
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# 推播目標，可填多位使用者（逗號分隔）
# 範例：LINE_USER_IDS=Uabc123,Udef456,Ughi789
LINE_USER_IDS=
